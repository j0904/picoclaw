FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
      ca-certificates tzdata \
    && rm -rf /var/lib/apt/lists/*

COPY docker/picoclaw-dev /usr/local/bin/picoclaw
RUN chmod +x /usr/local/bin/picoclaw

HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD curl -fs http://localhost:18790/health || exit 1

RUN groupadd -g 1000 picoclaw && \
    useradd -u 1000 -g picoclaw -m -s /bin/bash picoclaw

USER picoclaw
RUN /usr/local/bin/picoclaw onboard

ENTRYPOINT ["picoclaw"]
CMD ["gateway"]
